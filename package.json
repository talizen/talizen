{
  "name": "talizen",
  "version": "0.2.16",
  "description": "Talizen frontend SDK types for cms, form and core.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talizen/talizen.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js"
    },
    "./auth": {
      "types": "./auth.d.ts",
      "import": "./auth.js"
    },
    "./cms": {
      "types": "./cms.d.ts",
      "import": "./cms.js"
    },
    "./captcha-ui": {
      "types": "./captcha-ui.d.ts",
      "import": "./captcha-ui.js"
    },
    "./form": {
      "types": "./form.d.ts",
      "import": "./form.js"
    },
    "./func": {
      "types": "./func.d.ts",
      "import": "./func.js"
    },
    "./func-runtime": {
      "types": "./func-runtime.d.ts",
      "import": "./func-runtime.js"
    },
    "./server-runtime": {
      "types": "./server-runtime.d.ts",
      "import": "./server-runtime.js"
    },
    "./i18n": {
      "types": "./i18n.d.ts",
      "import": "./i18n.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev:serve": "serve dist -p 8787 --cors",
    "dev": "concurrently \"bun run build:watch\" \"bun run dev:serve\""
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "concurrently": "^9.2.1",
    "react": "^19.0.0",
    "serve": "^14.2.4",
    "typescript": "^5.9.2"
  }
}
