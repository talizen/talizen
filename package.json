{
  "name": "talizen",
  "version": "0.1.4",
  "description": "Talizen frontend SDK types for cms, form and core.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js"
    },
    "./cms": {
      "types": "./cms.d.ts",
      "import": "./cms.js"
    },
    "./captcha-ui": {
      "types": "./captcha-ui.d.ts",
      "import": "./captcha-ui.js"
    },
    "./form": {
      "types": "./form.d.ts",
      "import": "./form.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev:serve": "serve dist -p 8787 --cors",
    "dev": "concurrently \"bun run build:watch\" \"bun run dev:serve\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "serve": "^14.2.4",
    "typescript": "^5.9.2"
  }
}
