{
  "name": "talizen",
  "version": "0.1.1",
  "description": "Talizen frontend SDK types for cms, form and core.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js"
    },
    "./cms": {
      "types": "./cms.d.ts",
      "import": "./cms.js"
    },
    "./form": {
      "types": "./form.d.ts",
      "import": "./form.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}